# --- ROS 2 构建产物 (绝对忽略) ---
build/
install/
log/
*.log

# --- Python 缓存与字节码 ---
__pycache__/
*.py[cod]
*.class
*.so
.Python

# --- 虚拟环境 (如果你的 venv 在项目内) ---
# 注意：你的 g1venv 在上一级目录，所以这里不需要忽略它。
# 但如果未来有人在项目内创建 venv，这条规则会生效
venv/
.env/
.venv/

# --- IDE 配置文件 (可选，建议忽略以保持仓库干净) ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- 系统临时文件 ---
.DS_Store
Thumbs.db

# --- 其他常见忽略 ---
*.bak
*.tmp
